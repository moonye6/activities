<!-- pages/create/create.wxml — 创建活动 -->
<view class="page create-page">
  <view class="create-form">
    <!-- 活动标题 -->
    <view class="form-section">
      <input
        class="form-title-input"
        placeholder="给活动起个名字吧 🎯"
        placeholder-class="form-title-placeholder"
        value="{{form.title}}"
        bindinput="onInput"
        data-field="title"
        maxlength="30"
      />
      <view class="form-title-count">{{form.title.length}}/30</view>
    </view>

    <!-- 表单卡片 -->
    <view class="form-card card">
      <!-- 活动类型 -->
      <view class="form-cell" bindtap="onSelectType">
        <view class="form-cell__left">
          <text class="form-cell__icon">{{typeInfo.emoji || '🎯'}}</text>
          <text class="form-cell__label">活动类型</text>
        </view>
        <view class="form-cell__right">
          <text class="form-cell__value {{form.type ? 'form-cell__value--selected' : ''}}">
            {{typeInfo.label || '请选择'}}
          </text>
          <text class="form-cell__arrow">›</text>
        </view>
      </view>
      <view class="form-divider"></view>

      <!-- 活动时间 -->
      <picker mode="multiSelector" value="{{timePickerVal}}" range="{{timeRange}}" bindchange="onTimeChange">
        <view class="form-cell">
          <view class="form-cell__left">
            <text class="form-cell__icon">🕐</text>
            <text class="form-cell__label">活动时间</text>
          </view>
          <view class="form-cell__right">
            <text class="form-cell__value {{form.time ? 'form-cell__value--selected' : ''}}">
              {{form.time || '请选择时间'}}
            </text>
            <text class="form-cell__arrow">›</text>
          </view>
        </view>
      </picker>
      <view class="form-divider"></view>

      <!-- 活动地点 -->
      <view class="form-cell">
        <view class="form-cell__left">
          <text class="form-cell__icon">📍</text>
          <text class="form-cell__label">活动地点</text>
        </view>
        <input
          class="form-cell__input"
          placeholder="填写地点（可选）"
          placeholder-class="form-cell__placeholder"
          value="{{form.location}}"
          bindinput="onInput"
          data-field="location"
          maxlength="30"
        />
      </view>
      <view class="form-divider"></view>

      <!-- 人数限制 -->
      <view class="form-cell">
        <view class="form-cell__left">
          <text class="form-cell__icon">👥</text>
          <text class="form-cell__label">人数上限</text>
        </view>
        <view class="form-cell__right form-cell__stepper">
          <view class="stepper__btn stepper__btn--minus" bindtap="onCountChange" data-action="minus">－</view>
          <text class="stepper__val">{{form.maxCount}}</text>
          <view class="stepper__btn stepper__btn--plus" bindtap="onCountChange" data-action="plus">＋</view>
        </view>
      </view>
    </view>

    <!-- 可见范围 -->
    <view class="form-section-title">可见范围</view>
    <view class="visibility-options">
      <view
        wx:for="{{visibilityOptions}}"
        wx:key="value"
        class="visibility-item {{form.visibility === item.value ? 'visibility-item--active' : ''}}"
        bindtap="onVisibilityChange"
        data-value="{{item.value}}"
      >
        <text class="visibility-item__label">{{item.label}}</text>
        <text class="visibility-item__desc">{{item.desc}}</text>
      </view>
    </view>

    <!-- 活动标签 -->
    <view class="form-section-title">活动标签
      <text class="form-section-hint">（最多5个）</text>
    </view>
    <view class="tags-card card card-padding">
      <tag-selector
        systemTags="{{systemTags}}"
        customTags="{{customTags}}"
        selected="{{form.tags}}"
        showCustom="{{true}}"
        bindchange="onTagChange"
        bindcustomChange="onCustomTagChange"
      />
    </view>

    <!-- 占位 -->
    <view style="height:200rpx"></view>
  </view>

  <!-- 底部发布按钮 -->
  <view class="create-footer">
    <view class="create-footer__inner">
      <button
        class="btn btn-primary btn-full {{submitting ? 'btn-disabled' : ''}}"
        bindtap="onSubmit"
        loading="{{submitting}}"
        disabled="{{submitting}}"
      >
        {{submitting ? '发布中...' : '🚀 发起活动'}}
      </button>
    </view>
    <view class="safe-bottom"></view>
  </view>
</view>
