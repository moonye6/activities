/* pages/create/create.wxss */

.create-page {
  background: var(--color-bg);
  min-height: 100vh;
  padding-bottom: 0;
}

.create-form {
  padding: 24rpx 32rpx 0;
}

/* 标题输入 */
.form-section {
  position: relative;
  margin-bottom: 24rpx;
}

.form-title-input {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--color-border);
  width: 100%;
}

.form-title-placeholder {
  color: var(--color-text-tertiary);
  font-weight: 400;
}

.form-title-count {
  position: absolute;
  right: 0;
  bottom: 16rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 表单卡片 */
.form-card {
  margin-bottom: 24rpx;
}

/* 表单行 */
.form-cell {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  min-height: 96rpx;
}

.form-cell__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 160rpx;
}

.form-cell__icon {
  font-size: 32rpx;
  width: 40rpx;
  text-align: center;
}

.form-cell__label {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.form-cell__right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.form-cell__value {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.form-cell__value--selected {
  color: var(--color-text-primary);
}

.form-cell__arrow {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
}

.form-cell__input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.form-cell__placeholder {
  color: var(--color-text-tertiary);
}

.form-divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 0 28rpx;
}

/* 步进器 */
.form-cell__stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stepper__btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 300;
}

.stepper__btn--plus {
  background: var(--color-primary-pale);
  color: var(--color-primary);
}

.stepper__btn:active {
  opacity: 0.6;
}

.stepper__val {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  min-width: 48rpx;
  text-align: center;
}

/* 区块标题 */
.form-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin: 8rpx 0 16rpx;
}

.form-section-hint {
  font-weight: 400;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 可见范围 */
.visibility-options {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.visibility-item {
  flex: 1;
  padding: 20rpx 16rpx;
  border-radius: var(--radius-md);
  background: var(--color-white);
  border: 2rpx solid var(--color-border);
  text-align: center;
  transition: all 0.15s;
}

.visibility-item--active {
  background: var(--color-primary-pale);
  border-color: var(--color-primary);
}

.visibility-item__label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.visibility-item--active .visibility-item__label {
  color: var(--color-primary);
}

.visibility-item__desc {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  line-height: 1.3;
}

/* 标签区 */
.tags-card {
  margin-bottom: 24rpx;
}

/* 底部按钮 */
.create-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid var(--color-border);
  z-index: 100;
}

.create-footer__inner {
  padding: 20rpx 32rpx 0;
}

.btn-disabled {
  opacity: 0.6;
}
