<!-- pages/profile/profile.wxml — 个人中心 -->
<view class="page profile-page">
  <!-- 头部背景区 -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <!-- 头像 + 昵称一步授权区 -->
      <view wx:if="{{!userInfo.avatarUrl || !userInfo.nickName || userInfo.nickName === '新用户'}}" class="auth-wrap">
        <!-- 隐藏的 nickname input，微信选头像时会自动填入昵称 -->
        <input
          class="nick-input-hidden"
          type="nickname"
          id="nicknameInput"
          bindinput="onNickInput"
        />
        <!-- 头像选择按钮，点一次完成头像+昵称授权 -->
        <button
          class="profile-avatar-btn"
          open-type="chooseAvatar"
          bindchooseavatar="onChooseAvatar"
          style="width:120rpx;height:120rpx;min-width:120rpx;border-radius:60rpx;background:{{avatarColor}};padding:0;"
        >
          <image wx:if="{{userInfo.avatarUrl}}" class="profile-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
          <text wx:else class="profile-avatar__text">{{avatarText}}</text>
        </button>
        <view class="avatar-hint">点击头像一键授权</view>
      </view>

      <!-- 已完成授权：展示头像 + 昵称 -->
      <view wx:else class="auth-done-wrap">
        <button
          class="profile-avatar-btn"
          open-type="chooseAvatar"
          bindchooseavatar="onChooseAvatar"
          style="width:120rpx;height:120rpx;min-width:120rpx;border-radius:60rpx;padding:0;"
        >
          <image class="profile-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
        </button>
        <view class="profile-nickname" bindtap="onEditNick">
          {{userInfo.nickName}}<text class="nick-edit-icon"> ✎</text>
        </view>
      </view>

      <view class="profile-since">加入于 {{joinedAt}}</view>
    </view>
  </view>

  <!-- 数据统计卡 -->
  <view class="stats-card card">
    <view class="stat-item">
      <text class="stat-num">{{stats.created}}</text>
      <text class="stat-label">发起活动</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.joined}}</text>
      <text class="stat-label">参与活动</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.ended}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- 标签区 -->
  <view class="section-title">我的标签</view>
  <view class="my-tags card card-padding">
    <view wx:if="{{displayTags.length}}" class="tags-wrap">
      <view
        wx:for="{{displayTags}}"
        wx:key="key"
        class="tag {{item.isIdentity ? 'tag-identity' : 'tag-primary'}}"
      >
        <text wx:if="{{item.icon}}" class="tag-lock-icon">{{item.icon}}</text>
        <text>{{item.label}}</text>
        <text wx:if="{{item.hint}}" class="tag-hint"> · {{item.hint}}</text>
      </view>
    </view>
    <text wx:else class="empty-tags">暂无标签，在活动中添加标签后会展示在这里</text>
  </view>

  <!-- 个人属性 -->
  <view class="section-title">身份信息
    <text class="section-count">用于身份标签匹配</text>
  </view>
  <view class="attr-card card">
    <!-- 性别 -->
    <picker mode="selector" range="{{genderOptions}}" range-key="label" bindchange="onGenderChange">
      <view class="attr-cell">
        <view class="attr-cell__left">
          <text class="attr-cell__icon">👤</text>
          <text class="attr-cell__label">性别</text>
        </view>
        <view class="attr-cell__right">
          <text class="attr-cell__value">{{genderLabel}}</text>
          <text class="attr-cell__arrow">›</text>
        </view>
      </view>
    </picker>
    <view class="attr-divider"></view>

    <!-- 公司 -->
    <view class="attr-cell" wx:if="{{!editingCompany}}" bindtap="onEditCompany">
      <view class="attr-cell__left">
        <text class="attr-cell__icon">🏢</text>
        <text class="attr-cell__label">公司</text>
      </view>
      <view class="attr-cell__right">
        <text class="attr-cell__value">{{userInfo.company || '未设置'}}</text>
        <text class="attr-cell__arrow">›</text>
      </view>
    </view>
    <view class="attr-cell attr-cell--editing" wx:if="{{editingCompany}}">
      <view class="attr-cell__left">
        <text class="attr-cell__icon">🏢</text>
        <text class="attr-cell__label">公司</text>
      </view>
      <view class="attr-cell__input-wrap">
        <input
          class="attr-cell__input"
          placeholder="输入公司名称"
          value="{{companyInput}}"
          bindinput="onCompanyInput"
          bindconfirm="onCompanyConfirm"
          bindblur="onCompanyConfirm"
          focus="{{editingCompany}}"
          maxlength="20"
        />
      </view>
    </view>
    <view class="attr-divider"></view>

    <!-- 学校 -->
    <view class="attr-cell" wx:if="{{!editingSchool}}" bindtap="onEditSchool">
      <view class="attr-cell__left">
        <text class="attr-cell__icon">🎓</text>
        <text class="attr-cell__label">学校</text>
      </view>
      <view class="attr-cell__right">
        <text class="attr-cell__value">{{userInfo.school || '未设置'}}</text>
        <text class="attr-cell__arrow">›</text>
      </view>
    </view>
    <view class="attr-cell attr-cell--editing" wx:if="{{editingSchool}}">
      <view class="attr-cell__left">
        <text class="attr-cell__icon">🎓</text>
        <text class="attr-cell__label">学校</text>
      </view>
      <view class="attr-cell__input-wrap">
        <input
          class="attr-cell__input"
          placeholder="输入学校名称"
          value="{{schoolInput}}"
          bindinput="onSchoolInput"
          bindconfirm="onSchoolConfirm"
          bindblur="onSchoolConfirm"
          focus="{{editingSchool}}"
          maxlength="20"
        />
      </view>
    </view>
  </view>

  <!-- 活动记录 -->
  <view class="section-title">活动记录
    <text class="section-count">共 {{myActivities.length}} 个</text>
  </view>

  <view wx:if="{{myActivities.length === 0}}" class="empty-state">
    <text class="empty-icon">🎈</text>
    <text>还没有活动记录</text>
  </view>

  <view wx:else class="activity-list">
    <view
      wx:for="{{myActivities}}"
      wx:key="_id"
      class="history-card card"
      bindtap="onActivityTap"
      data-id="{{item._id}}"
    >
      <view class="history-stripe" style="background:{{item.typeInfo.color}}"></view>
      <view class="history-body">
        <view class="history-header">
          <text class="history-title text-clamp1">{{item.title}}</text>
          <view class="tag {{item.statusInfo.tagClass}}">{{item.statusInfo.label}}</view>
        </view>
        <view class="history-meta">
          <text class="history-time">🕐 {{item.timeLabel}}</text>
          <text class="history-role" style="color:{{item.roleColor}}">{{item.roleLabel}}</text>
        </view>
      </view>
    </view>
  </view>

  <view style="height:60rpx"></view>
</view>
