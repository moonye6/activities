/* pages/detail/detail.wxss */

.detail-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

/* 封面 */
.detail-cover {
  height: 360rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  flex-shrink: 0;
}

.cover-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0.45) 100%);
}

.cover-content {
  position: relative;
  z-index: 1;
  padding: 0 32rpx 28rpx;
  width: 100%;
}

.cover-type-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10rpx);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  margin-bottom: 16rpx;
}

.cover-emoji { font-size: 28rpx; }

.cover-type-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.95);
  font-weight: 500;
}

.cover-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  margin-bottom: 12rpx;
}

.cover-status {
  font-size: 22rpx;
}

/* 滚动区 */
.detail-scroll {
  flex: 1;
  overflow: hidden;
  padding: 24rpx 32rpx 0;
}

/* 信息卡片 */
.detail-card {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
}

.info-icon { font-size: 32rpx; margin-top: 2rpx; }

.info-svg {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.info-value {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.info-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 4rpx;
}

/* 身份标签样式 */
.tag-identity {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  background: rgba(255, 149, 0, 0.1);
  color: #FF9500;
  border: 1rpx solid rgba(255, 149, 0, 0.3);
}

.tag-lock-icon {
  font-size: 18rpx;
}

.tag-hint {
  font-size: 20rpx;
  opacity: 0.8;
}

.info-divider {
  height: 1rpx;
  background: var(--color-border);
}

/* 区块标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin: 0 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-count {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-text-tertiary);
}

/* 参与者卡片 */
.participants-card {
  margin-bottom: 24rpx;
}

.rsvp-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.rsvp-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  flex: 1;
}

.rsvp-stat__num {
  font-size: 40rpx;
  font-weight: 700;
}

.rsvp-stat__label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.rsvp-stat--yes .rsvp-stat__num { color: var(--color-success); }
.rsvp-stat--maybe .rsvp-stat__num { color: var(--color-warning); }
.rsvp-stat--no .rsvp-stat__num { color: var(--color-danger); }

.rsvp-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-border);
}

/* 环形进度条 */
.ring-progress-wrap {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.ring-progress-area {
  flex-shrink: 0;
}

.ring-progress {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-inner {
  position: absolute;
  inset: 16rpx;
  background: var(--color-surface);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.ring-inner__pct {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.ring-inner__label {
  font-size: 18rpx;
  color: var(--color-text-tertiary);
  line-height: 1;
}

.ring-progress-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ring-info__hint {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.ring-info__num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.ring-info__total {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 头像列表 */
.avatar-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.avatar-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.avatar-text {
  font-size: 32rpx;
  color: white;
  font-weight: 600;
}

.avatar-status {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 3rpx solid white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-status-icon {
  font-size: 16rpx;
  color: white;
  font-weight: 700;
}

.avatar-name {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  max-width: 80rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* RSVP 操作 */
.my-rsvp-card {
  margin-bottom: 24rpx;
}

.my-rsvp-hint {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 20rpx;
}

.rsvp-actions {
  display: flex;
  gap: 16rpx;
}

.rsvp-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  background: var(--color-bg);
  transition: all 0.15s;
}

.rsvp-btn:active { animation: btn-bounce 0.3s ease; }

@keyframes btn-bounce {
  0%   { transform: scale(1); }
  40%  { transform: scale(0.94); }
  70%  { transform: scale(1.03); }
  100% { transform: scale(1); }
}

.rsvp-btn__icon {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
}

.rsvp-btn__svg {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.rsvp-btn__label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.rsvp-btn--active-yes {
  background: rgba(52,199,89,0.1);
  border-color: var(--color-success);
}
.rsvp-btn--active-yes .rsvp-btn__icon,
.rsvp-btn--active-yes .rsvp-btn__label { color: var(--color-success); }

.rsvp-btn--active-maybe {
  background: rgba(255,149,0,0.1);
  border-color: var(--color-warning);
}
.rsvp-btn--active-maybe .rsvp-btn__icon,
.rsvp-btn--active-maybe .rsvp-btn__label { color: var(--color-warning); }

.rsvp-btn--active-no {
  background: rgba(255,59,48,0.08);
  border-color: var(--color-danger);
}
.rsvp-btn--active-no .rsvp-btn__icon,
.rsvp-btn--active-no .rsvp-btn__label { color: var(--color-danger); }

/* 创建者信息 */
.creator-card {
  margin-bottom: 24rpx;
}

.creator-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.creator-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.creator-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.creator-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.creator-role {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.creator-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* loading 动画 */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 200rpx auto;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
