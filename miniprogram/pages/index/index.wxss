/* pages/index/index.wxss */

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

/* 顶部导航 */
.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
}

.navbar__brand {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.navbar__logo {
  font-size: 40rpx;
}

.navbar__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 2rpx;
}

.navbar__btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-bg);
  font-size: 32rpx;
}

.navbar__btn:active {
  background: var(--color-primary-pale);
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: var(--color-white);
  padding: 0 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.tab-bar__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  position: relative;
  transition: color 0.2s;
}

.tab-bar__item--active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-bar__item--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

.tab-bar__badge {
  min-width: 32rpx;
  height: 32rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: white;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* 滚动区 */
.list-scroll {
  flex: 1;
  overflow: hidden;
}

/* 骨架屏 */
.skeleton-wrap {
  padding-top: 24rpx;
}

.skeleton-card {
  display: flex;
  margin: 0 32rpx 24rpx;
  height: 160rpx;
  background: var(--color-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.skeleton-stripe {
  width: 8rpx;
  background: linear-gradient(180deg, #f0f0f0 0%, #e8e8e8 100%);
  animation: shimmer 1.2s ease-in-out infinite;
}

.skeleton-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  justify-content: center;
}

.skeleton-line {
  height: 24rpx;
  border-radius: var(--radius-sm);
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s ease-in-out infinite;
}

.skeleton-line--title { width: 60%; height: 30rpx; }
.skeleton-line--short { width: 35%; }
.skeleton-line--medium { width: 50%; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 列表底部 */
.list-footer {
  text-align: center;
  padding: 32rpx 0 48rpx;
}

.list-footer__text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  box-shadow: var(--shadow-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: transform 0.2s, box-shadow 0.2s;
}

.fab:active,
.fab--pressed {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(255,107,53,0.25);
}

.fab__icon {
  color: white;
  font-size: 52rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}
