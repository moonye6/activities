<!-- pages/index/index.wxml — 首页：活动列表 -->
<view class="page">
  <!-- 顶部导航 -->
  <view class="navbar">
    <view class="navbar__brand">
      <text class="navbar__logo">🎯</text>
      <text class="navbar__title">活动圈</text>
    </view>
    <view class="navbar__actions">
      <view class="navbar__btn" bindtap="onSearch">
        <text>🔍</text>
      </view>
    </view>
  </view>

  <!-- 漂流瓶入口横幅 -->
  <view class="drift-banner" bindtap="onDriftTap">
    <view class="drift-banner__left">
      <text class="drift-banner__icon">🍶</text>
      <view>
        <text class="drift-banner__title">漂流瓶</text>
        <text class="drift-banner__sub">与陌生人聊聊活动故事</text>
      </view>
    </view>
    <view class="drift-banner__right">
      <text class="drift-banner__quota">今日捞瓶 {{driftFishRemain}}/1</text>
      <text class="drift-banner__arrow">›</text>
    </view>
  </view>

  <!-- 分类 Tab -->
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="tab-bar__item {{activeTab === item.value ? 'tab-bar__item--active' : ''}}"
      bindtap="onTabChange"
      data-value="{{item.value}}"
    >
      <text>{{item.label}}</text>
      <view class="tab-bar__badge" wx:if="{{item.count > 0}}">{{item.count}}</view>
    </view>
  </view>

  <!-- 活动列表 -->
  <scroll-view
    class="list-scroll"
    scroll-y
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore"
  >
    <!-- loading 骨架 -->
    <view class="skeleton-wrap" wx:if="{{loading && activities.length === 0}}">
      <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-stripe"></view>
        <view class="skeleton-body">
          <view class="skeleton-line skeleton-line--title"></view>
          <view class="skeleton-line skeleton-line--short"></view>
          <view class="skeleton-line skeleton-line--medium"></view>
        </view>
      </view>
    </view>

    <!-- 空状态 — 引导型插画 -->
    <view class="empty-guide" wx:elif="{{!loading && activities.length === 0}}">
      <view class="empty-ball-wrap">
        <view class="empty-ball">
          <text class="empty-ball__emoji">🎯</text>
        </view>
        <view class="empty-ball__shadow"></view>
      </view>
      <text class="empty-guide__title">还没有活动</text>
      <text class="empty-guide__desc">来发起第一个，约上好友一起玩 ✨</text>
      <button class="btn btn-primary mt-24 empty-guide__btn" catchtap="onCreateTap">
        发起第一个活动
      </button>
    </view>

    <!-- 活动卡片流 -->
    <block wx:else>
      <activity-card
        wx:for="{{activities}}"
        wx:key="_id"
        activity="{{item}}"
        currentUserId="{{currentUserId}}"
        bind:tap="onCardTap"
      />
      <view class="list-footer">
        <text wx:if="{{noMore}}" class="list-footer__text">已经到底啦 ~</text>
        <text wx:elif="{{loadingMore}}" class="list-footer__text">加载中...</text>
      </view>
    </block>
  </scroll-view>

  <!-- FAB 发起按钮 -->
  <view class="fab" bindtap="onCreateTap" hover-class="fab--pressed">
    <text class="fab__icon">+</text>
  </view>
</view>
