#!/bin/sh
# .husky/pre-commit
# 微信小程序构建质量守卫
# 每次 git commit 前自动执行，失败则阻止提交

echo ""
echo "🔍 运行构建质量检查..."
echo ""

node scripts/check-build.js

EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ 构建质量检查未通过，提交已中止。"
  echo "   请修复上述问题后重新提交。"
  echo ""
  exit 1
fi

echo ""
echo "✅ 构建质量检查通过。"
echo ""
